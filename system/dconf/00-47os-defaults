[org/cinnamon]
app-menu-icon-name='47os-logo'
system-icon='47os-logo'
panels-enabled=['1:0:top']
panels-height=['1:28']
panel-zone-icon-sizes='[{"panelId": 1, "left": 22, "center": 0, "right": 24}]'
panel-zone-symbolic-icon-sizes='[{"panelId": 1, "left": 28, "center": 28, "right": 16}]'
enabled-applets=['panel1:left:0:menu@cinnamon.org:0', 'panel1:right:0:systray@cinnamon.org:3', 'panel1:right:1:notifications@cinnamon.org:5', 'panel1:right:2:keyboard@cinnamon.org:8', 'panel1:right:3:brightness@custom:20', 'panel1:right:4:fake-wifi@custom:17', 'panel1:right:5:sound@cinnamon.org:11', 'panel1:right:6:fake-battery@custom:16', 'panel1:right:7:calendar@cinnamon.org:13']
panel-scale-text-icons=true
startup-animation=true
enable-vfade=false
desktop-effects-workspace=true
desktop-effects=true
desktop-effects-map='move'
desktop-effects-close='scale'
desktop-effects-minimize='traditional'
window-effect-speed=1
enabled-extensions=['compiz-windows-effect@hermes83.github.com', 'CinnamonBurnMyWindows@klangman', 'CinnamonMagicLamp@klangman']

[org/cinnamon/theme]
name='WhiteSur-Dark'

[org/cinnamon/desktop/interface]
cursor-theme='WhiteSur-cursors'
gtk-theme='WhiteSur-Dark'
icon-theme='WhiteSur-dark'
font-name='SF Pro Display 10'

[org/cinnamon/desktop/font-rendering]
antialiasing='rgba'
hinting='slight'

[org/cinnamon/desktop/wm/preferences]
theme='WhiteSur-Dark'
titlebar-font='SF Pro Display Bold 10'
button-layout=':minimize,maximize,close'
num-workspaces=4
workspace-names=['Desktop 1', 'Desktop 2', 'Desktop 3', 'Desktop 4']

[org/cinnamon/desktop/background]
picture-uri='file:///usr/share/backgrounds/sequoia-sunrise.jpg'
picture-options='zoom'

[org/cinnamon/desktop/screensaver]
lock-enabled=false
lock-delay=uint32 0
allow-media-control=false
floating-widgets=false
show-album-art=false
show-info-panel=true
show-notifications=false
font-date='%A, %B %-d'
font-time='%-I:%M %p'

[org/cinnamon/desktop/sound]
event-sounds=true

[org/cinnamon/desktop/peripherals/keyboard]
numlock-state=true

[org/cinnamon/muffin]
draggable-border-width=10
edge-tiling=true
placement-mode='pointer'
unredirect-fullscreen-windows=true

[org/nemo/desktop]
computer-icon-visible=false
home-icon-visible=false
network-icon-visible=false
trash-icon-visible=false
volumes-visible=false
